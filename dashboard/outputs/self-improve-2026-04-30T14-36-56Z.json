        "level": "h3"
      },
      "children": []
    },
    "why-text": {
      "type": "Text",
      "props": {
        "text": "ISS-001 auth outage (Apr 16-30) left all 14 skills with success_rate of 0% despite now running perfectly. The health guard (PR #1) and any future monitoring would operate on meaningless data — a skill succeeding 100% of the time since recovery would still show 1% overall.",
        "variant": "body"
      },
      "children": []
