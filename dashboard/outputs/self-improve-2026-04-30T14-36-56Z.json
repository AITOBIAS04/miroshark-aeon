    "intro-text": {
      "type": "Text",
      "props": {
        "text": "After the 15-day auth outage (ISS-001), every skill success_rate in cron-state.json was permanently stuck at 0-1% — poisoned by 200-300 phantom failures from a single root cause. This adds automatic recovery detection and metric reset.",
        "variant": "body"
      },
      "children": []
