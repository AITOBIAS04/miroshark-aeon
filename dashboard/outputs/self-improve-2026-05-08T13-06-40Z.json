        "level": "h3"
      }
    },
    "text_impact": {
      "type": "Text",
      "props": {
        "text": "More diverse articles across the 3x/week schedule. No more risk of repeating the same angle category within 14 days. Graceful degradation when the rotation is exhausted."
      }
    },
