    "heading_how": {
      "type": "Heading",
      "props": {
        "text": "How it works:",
        "level": "h2"
      }
    },
    "text_how": {
      "type": "Text",
      "props": {
        "text": "The service reads the same trajectory.json every other export surface uses, then expands each round's belief_positions map into individual rows. For each agent × round, it computes the mean belief across all tracked topics, classifies the stance using the standard ±0.2 threshold, counts posts from viral_posts, and flags stance transitions by comparing against the previous round. Agent names and archetypes are enriched from the profile files when available. The CSV renderer serializes booleans as 'true'/'false' strings for pandas compatibility. The JSONL form emits one JSON object per line with the same locked column order."
      }
    },
