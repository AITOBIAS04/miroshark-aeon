    "how_title": {
      "type": "Heading",
      "props": {
        "text": "How it works",
        "level": "h3"
      }
    },
    "how_text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "how_p1",
        "how_p2"
      ]
    },
    "how_p1": {
      "type": "Text",
      "props": {
        "text": "The /query endpoint reuses the exact context-building logic from the UI trace interview: it loads the agent's profile from reddit_profiles.json, the simulation scenario from config, and builds a complete round-by-round trace from the JSONL action logs. The agent responds in character, citing specific posts and round numbers."
      }
    },
    "how_p2": {
      "type": "Text",
      "props": {
        "text": "Server-side sessions (via session_id parameter) persist the last 4 Q&A pairs on disk for multi-turn dialogue — callers don't need to manage history. Rate limiting (20 queries per simulation per 5 minutes) prevents cost explosions from automation loops. All queries are also saved to the shared interview transcript, so UI and API interrogations appear in the same history."
      }
    },
