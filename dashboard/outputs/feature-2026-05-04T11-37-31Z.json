    "endpoints_label": {
      "type": "Text",
      "props": {
        "text": "4 new endpoints:",
        "variant": "lead"
      }
    },
    "endpoint_1": {
      "type": "Text",
      "props": {
        "text": "• GET /agents — list all agents with metadata, stance, influence rank"
      }
    },
    "endpoint_2": {
      "type": "Text",
      "props": {
        "text": "• GET /agents/<name>/profile — full bio + per-round belief history from trajectory.json"
      }
    },
    "endpoint_3": {
      "type": "Text",
      "props": {
        "text": "• POST /agents/<name>/query — trace-grounded interrogation with server-side session management and rate limiting"
      }
    },
    "endpoint_4": {
      "type": "Text",
      "props": {
        "text": "• GET /interview-sessions — list all saved sessions"
      }
    },
    "built_files": {
