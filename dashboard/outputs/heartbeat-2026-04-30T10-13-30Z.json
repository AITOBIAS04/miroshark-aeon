      }
    },
    "skill-6": {
      "type": "Badge",
      "props": {
        "text": "push-recap",
        "variant": "outline"
      }
    },
    "skill-7": {
      "type": "Badge",
      "props": {
        "text": "feature",
        "variant": "outline"
      }
    },
    "sep-5": {
      "type": "Separator",
      "props": {}
    },
    "section-issue": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "heading-issue",
        "text-issue"
      ]
    },
    "heading-issue": {
      "type": "Heading",
      "props": {
        "text": "Issue Tracking",
        "level": "h3"
      }
    },
    "text-issue": {
