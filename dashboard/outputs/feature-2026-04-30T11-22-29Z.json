    "feature-name": {
      "type": "Heading",
      "props": {
        "text": "Atom Feed for Completed Simulations (/feed.xml)",
        "level": "h2"
      }
    },
    "intro-para1": {
      "type": "Text",
      "props": {
        "text": "MiroShark now publishes an Atom (RFC 4287) feed at /feed.xml listing the last 20 completed simulations. Teams subscribe via Feedly, n8n, Zapier, Slack RSS app, or any standard feed reader and get notified whenever a simulation completes — zero config, zero new dependencies."
      }
    },
    "intro-para2": {
      "type": "Text",
      "props": {
        "text": "Why it matters: Every other output surface (share cards, transcripts, embeds) requires someone to visit the app. The feed flips it — simulations come to you. Wire it into n8n → Discord and your channel gets a post every time a sim finishes. Subscribe in Feedly and browse results over coffee. It's the missing push layer for teams that run MiroShark unattended."
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
