{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "heartbeat"
      },
      "children": [
        "status",
        "sep1",
        "skills_section",
        "sep2",
        "pr_section",
        "sep3",
        "footer"
      ]
    },
    "status": {
      "type": "Alert",
      "props": {
