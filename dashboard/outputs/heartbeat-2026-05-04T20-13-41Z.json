        "text": "repo-pulse"
      }
    },
    "skill6": {
      "type": "Badge",
      "props": {
        "text": "self-improve"
      }
    },
    "skill7": {
      "type": "Badge",
      "props": {
        "text": "repo-actions"
      }
    },
    "skill8": {
      "type": "Badge",
