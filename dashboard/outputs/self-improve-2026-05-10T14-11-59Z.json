    "problem_text": {
      "type": "Text",
      "props": {
        "text": "Heartbeat auto-trigger now fails fast on permission denial. Previously, the heartbeat skill attempted gh workflow run for every missing skill individually — always receiving HTTP 403 because the integration token lacks workflows scope. Now it tests the first dispatch and, on 403, skips all remaining attempts with one actionable message."
      },
      "children": []
    },
