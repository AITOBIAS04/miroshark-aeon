        "text": "Why",
        "level": "h3"
      },
      "children": []
    },
    "why_text": {
      "type": "Text",
      "props": {
        "text": "Observed on May 8, 9, and 10 — heartbeat tried and failed to dispatch repo-article and fetch-tweets, creating repetitive \"blocked (HTTP 403)\" log entries each time. The permission issue is persistent, not transient."
      },
      "children": []
    },
