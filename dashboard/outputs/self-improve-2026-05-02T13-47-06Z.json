{
  "root": "main-card",
  "state": {},
  "elements": {
    "main-card": {
      "type": "Card",
      "props": {
        "title": "Agent Self-Improvement"
      },
      "children": [
        "content-stack"
      ]
    },
    "content-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "date-badge",
        "sep1",
        "intro-text",
        "sep2",
        "why-section",
        "sep3",
        "changed-section",
        "sep4",
        "impact-section",
        "sep5",
        "pr-section"
      ]
    },
    "date-badge": {
      "type": "Badge",
      "props": {
        "text": "2026-05-02"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "intro-text": {
      "type": "Text",
      "props": {
        "text": "Fixed heartbeat false positives for */N day-of-month cron schedules. The heartbeat skill correctly handled day-of-week patterns (Sundays, Mondays, etc.) but had no logic for */N day-of-month patterns used by self-improve, repo-actions, and repo-article."
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "why-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "why-heading",
        "why-text"
      ]
    },
    "why-heading": {
      "type": "Heading",
      "props": {
        "text": "Why",
        "level": "h2"
      }
    },
    "why-text": {
      "type": "Text",
      "props": {
        "text": "On even-numbered days (today is May 2), heartbeat would flag these three */2 skills as \"missing\" even though they only run on odd days. This generated noisy false-positive notifications every other day and triggered failed dispatch attempts."
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "changed-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "changed-heading",
        "changed-text"
      ]
    },
    "changed-heading": {
      "type": "Heading",
      "props": {
        "text": "What changed",
        "level": "h2"
      }
    },
    "changed-text": {
      "type": "Text",
      "props": {
        "text": "skills/heartbeat/SKILL.md: Added */N day-of-month matching rule with formula (day - 1) % N == 0, plus POSIX cron OR behavior for combined day-of-month + day-of-week fields"
      }
    },
    "sep4": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "impact-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "impact-heading",
        "impact-text"
      ]
    },
    "impact-heading": {
      "type": "Heading",
      "props": {
        "text": "Impact",
        "level": "h2"
      }
    },
    "impact-text": {
      "type": "Text",
      "props": {
        "text": "Eliminates recurring false-positive alerts on ~15 days per month. Heartbeat reports become trustworthy — every flagged skill is genuinely missing, not just off-schedule."
      }
    },
    "sep5": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "pr-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "pr-heading",
        "pr-link"
      ]
    },
    "pr-heading": {
      "type": "Heading",
      "props": {
        "text": "PR",
        "level": "h2"
      }
    },
    "pr-link": {
      "type": "StoryLink",
      "props": {
        "title": "miroshark-aeon #3",
        "href": "https://github.com/AITOBIAS04/miroshark-aeon/pull/3",
        "source": "GitHub"
      }
    }
  }
}
