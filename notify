#!/usr/bin/env bash
set -euo pipefail
MSG="$1"

# Telegram: 4096 char limit, strict Markdown parsing
if [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -n "${TELEGRAM_CHAT_ID:-}" ]; then
  TG_MSG="$MSG"
  # Truncate to 4000 chars (leave room for truncation notice)
  if [ ${#TG_MSG} -gt 4000 ]; then
    TG_MSG="${TG_MSG:0:3990}

...(truncated)"
  fi
  # Try Markdown first, fall back to plain text if it fails
  curl -sf -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg chat "$TELEGRAM_CHAT_ID" --arg text "$TG_MSG" '{chat_id: $chat, text: $text, parse_mode: "Markdown"}')" > /dev/null 2>&1 || \
  curl -sf -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg chat "$TELEGRAM_CHAT_ID" --arg text "$TG_MSG" '{chat_id: $chat, text: $text}')" > /dev/null 2>&1 || true
fi

# Discord: 2000 char limit
if [ -n "${DISCORD_WEBHOOK_URL:-}" ]; then
  DC_MSG="$MSG"
  if [ ${#DC_MSG} -gt 2000 ]; then
    DC_MSG="${DC_MSG:0:1990}

...(truncated)"
  fi
  curl -sf -X POST "$DISCORD_WEBHOOK_URL" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg text "$DC_MSG" '{content: $text}')" > /dev/null || true
fi
# Slack: 40000 char limit for webhooks, but keep it reasonable at 4000
if [ -n "${SLACK_WEBHOOK_URL:-}" ]; then
  SL_MSG="$MSG"
  if [ ${#SL_MSG} -gt 4000 ]; then
    SL_MSG="${SL_MSG:0:3990}

...(truncated)"
  fi
  curl -sf -X POST "$SLACK_WEBHOOK_URL" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg text "$SL_MSG" '{text: $text}')" > /dev/null || true
fi
# json-render channel — save raw message for post-run conversion
if [ "${JSONRENDER_ENABLED:-false}" = "true" ] && [ -n "${SKILL_NAME:-}" ]; then
  mkdir -p dashboard/outputs
  echo "$MSG" > "dashboard/outputs/.pending-${SKILL_NAME}.md"
fi
